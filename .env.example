ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
MAX_TOKENS=8192

# To use OpenAI Codex (ChatGPT Plus/Pro subscription):
# DEFAULT_MODEL=openai-codex/codex-mini-latest
# Credentials are stored automatically in ~/.avoid-agent/openai-codex-credentials.json

# To use a remote Ollama instance:
# OLLAMA_REMOTE_HOST=http://10.168.10.17:11434
# DEFAULT_MODEL=ollama-remote/devstral-small:latest

